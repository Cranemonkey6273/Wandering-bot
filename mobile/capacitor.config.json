{
  "appId": "com.dayzwanderingbot.app",
  "appName": "Wandering Bot",
  "webDir": "web",
  "server": {
    "url": "https://dayzwanderingbot.com/app?source=native_android",
    "cleartext": false,
    "allowNavigation": [
      "dayzwanderingbot.com",
      "www.dayzwanderingbot.com",
      "*.dayzwanderingbot.com",
      "discord.com",
      "*.discord.com"
    ]
  },
  "plugins": {
    "App": {
      "launchUrl": "https://dayzwanderingbot.com/app?source=native_android"
    },
    "Keyboard": {
      "resize": "body"
    },
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#020706",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#020706",
      "overlaysWebView": false
    }
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true
  },
  "ios": {
    "contentInset": "automatic",
    "limitsNavigationsToAppBoundDomains": false
  }
}
