+def _get_translation_rules(config):
+    """Return all configured translation rules for a guild.
+
+    Supports both the new multi-rule shape (`config["translations"] = [ ... ]`)
+    and the legacy single-rule shape (`config["translation"] = { ... }`). The
+    legacy shape is transparently exposed as a single-element list so existing
+    setups keep working until the admin re-runs `/translationconfig`.
+    """
+    rules = config.get("translations")
+    if isinstance(rules, list):
+        return [r for r in rules if isinstance(r, dict)]
+    legacy = config.get("translation")
+    if isinstance(legacy, dict) and legacy.get("enabled"):
+        return [legacy]
+    return []
+
+
+def _rule_matches_channel(rule, channel_id):
+    """A rule fires when no source_channel is set (all channels) or the
+    incoming message channel matches the rule's source_channel_id."""
+    if not rule.get("enabled", True):
+        return False
+    src_id = rule.get("source_channel_id")
+    if not src_id:
+        return True
+    try:
+        return int(src_id) == int(channel_id)
+    except (TypeError, ValueError):
+        return False
+
